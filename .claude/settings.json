{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(git stash *)",
      "Bash(pnpm *)",
      "Bash(gh issue *)"
    ],
    "ask": [
      "Bash(rm *)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.gcp/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}